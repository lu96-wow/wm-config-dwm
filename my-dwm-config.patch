 void
+togglefullscreen(const Arg *arg)
+{
+	if (!selmon->sel)
+		return;
+	setfullscreen(selmon->sel, !selmon->sel->isfullscreen);
+}
+
+void
+killworkspace(const Arg *arg)
+{
+	Client *c;
+	Window *wins;
+	int i, n = 0;
+	unsigned int curtag;
+
+	curtag = selmon->pertag->curtag;
+	if (curtag == 0)
+		return;
+
+	for (c = selmon->clients; c; c = c->next)
+		if (c->tags & (1 << (curtag - 1)))
+			n++;
+	if (n == 0)
+		return;
+
+	wins = ecalloc(n, sizeof(Window));
+	for (i = 0, c = selmon->clients; c; c = c->next)
+		if (c->tags & (1 << (curtag - 1)))
+			wins[i++] = c->win;
+
+	for (i = 0; i < n; i++) {
+		c = wintoclient(wins[i]);
+		if (c) {
+			if (!sendevent(c, wmatom[WMDelete])) {
+				XGrabServer(dpy);
+				XSetErrorHandler(xerrordummy);
+				XSetCloseDownMode(dpy, DestroyAll);
+				XKillClient(dpy, c->win);
+				XSync(dpy, False);
+				XSetErrorHandler(xerror);
+				XUngrabServer(dpy);
+			}
+		}
+	}
+	free(wins);
+
+	selmon->pertag->nmasters[curtag] = nmaster;
+	selmon->pertag->mfacts[curtag] = mfact;
+	selmon->pertag->ltidxs[curtag][0] = &layouts[0];
+	selmon->pertag->ltidxs[curtag][1] = &layouts[1 % LENGTH(layouts)];
+	selmon->pertag->sellts[curtag] = 0;
+	selmon->pertag->showbars[curtag] = showbar;
+	selmon->pertag->sel[curtag] = NULL;
+
+	selmon->nmaster = selmon->pertag->nmasters[curtag];
+	selmon->mfact = selmon->pertag->mfacts[curtag];
+	selmon->sellt = selmon->pertag->sellts[curtag];
+	selmon->lt[selmon->sellt] = selmon->pertag->ltidxs[curtag][selmon->sellt];
+	selmon->lt[selmon->sellt^1] = selmon->pertag->ltidxs[curtag][selmon->sellt^1];
+
+	focus(NULL);
+	arrange(selmon);
+}
+
+void
+pushclient(const Arg *arg)
+{
+	Client *sel = selmon->sel, *c;
+
+	if (!sel || (sel->isfullscreen && lockfullscreen))
+		return;
+
+	if (arg->i > 0) {
+		c = sel->next;
+		if (!c)
+			return;
+		detach(sel);
+		detachstack(sel);
+		detach(c);
+		detachstack(c);
+		attach(sel);
+		attach(c);
+		attachstack(sel);
+		attachstack(c);
+	} else {
+		if (selmon->clients == sel)
+			return;
+		for (c = selmon->clients; c && c->next != sel; c = c->next);
+		detach(sel);
+		detachstack(sel);
+		detach(c);
+		detachstack(c);
+		attach(c);
+		attach(sel);
+		attachstack(c);
+		attachstack(sel);
+	}
+
+	arrange(selmon);
+	focus(sel);
+}
